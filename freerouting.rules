
(rules PCB freerouting.dsn
  (snap_angle 
    fortyfive_degree
  )
  (autoroute_settings
    (fanout off)
    (autoroute on)
    (postroute off)
    (vias on)
    (via_costs 50)
    (plane_via_costs 5)
    (start_ripup_costs 100)
    (start_pass_no 1)
    (layer_rule F.Cu
      (active on)
      (preferred_direction horizontal)
      (preferred_direction_trace_costs 2.2)
      (against_preferred_direction_trace_costs 5.1)
    )
    (layer_rule In1.Cu
      (active off)
      (preferred_direction vertical)
      (preferred_direction_trace_costs 1.0)
      (against_preferred_direction_trace_costs 3.2)
    )
    (layer_rule In2.Cu
      (active on)
      (preferred_direction vertical)
      (preferred_direction_trace_costs 1.0)
      (against_preferred_direction_trace_costs 3.9)
    )
    (layer_rule In3.Cu
      (active on)
      (preferred_direction horizontal)
      (preferred_direction_trace_costs 1.0)
      (against_preferred_direction_trace_costs 3.2)
    )
    (layer_rule In4.Cu
      (active off)
      (preferred_direction horizontal)
      (preferred_direction_trace_costs 1.0)
      (against_preferred_direction_trace_costs 3.9)
    )
    (layer_rule B.Cu
      (active on)
      (preferred_direction vertical)
      (preferred_direction_trace_costs 2.2)
      (against_preferred_direction_trace_costs 4.4)
    )
  )
  (rule
    (width 150.0)
    (clearance 200.0)
    (clearance 75.0 (type smd_to_turn_gap))
    (clearance 50.0 (type smd))
    (clearance 200.0 (type "kicad_default"))
    (clearance 200.0 (type 90ohm))
    (clearance 200.0 (type 100ohm))
  )
  (padstack "Via[0-5]_450:300_um"
    (shape
      (circle F.Cu 450.0 0.0 0.0)
    )
    (shape
      (circle In1.Cu 450.0 0.0 0.0)
    )
    (shape
      (circle In2.Cu 450.0 0.0 0.0)
    )
    (shape
      (circle In3.Cu 450.0 0.0 0.0)
    )
    (shape
      (circle In4.Cu 450.0 0.0 0.0)
    )
    (shape
      (circle B.Cu 450.0 0.0 0.0)
    )
    (attach off)
  )
  (padstack "Via[0-5]_600:300_um"
    (shape
      (circle F.Cu 600.0 0.0 0.0)
    )
    (shape
      (circle In1.Cu 600.0 0.0 0.0)
    )
    (shape
      (circle In2.Cu 600.0 0.0 0.0)
    )
    (shape
      (circle In3.Cu 600.0 0.0 0.0)
    )
    (shape
      (circle In4.Cu 600.0 0.0 0.0)
    )
    (shape
      (circle B.Cu 600.0 0.0 0.0)
    )
    (attach off)
  )
  (via 
    "Via[0-5]_450:300_um" "Via[0-5]_450:300_um" default
  )
  (via 
    "Via[0-5]_600:300_um" "Via[0-5]_600:300_um" default
  )
  (via 
    "Via[0-5]_450:300_um-kicad_default" "Via[0-5]_450:300_um" "kicad_default"
  )
  (via 
    "Via[0-5]_600:300_um-kicad_default" "Via[0-5]_600:300_um" "kicad_default"
  )
  (via 
    "Via[0-5]_450:300_um-90ohm" "Via[0-5]_450:300_um" 90ohm
  )
  (via 
    "Via[0-5]_600:300_um-90ohm" "Via[0-5]_600:300_um" 90ohm
  )
  (via 
    "Via[0-5]_450:300_um-100ohm" "Via[0-5]_450:300_um" 100ohm
  )
  (via 
    "Via[0-5]_600:300_um-100ohm" "Via[0-5]_600:300_um" 100ohm
  )
  (via_rule
    default "Via[0-5]_450:300_um"
  )
  (via_rule
    "kicad_default" "Via[0-5]_450:300_um-kicad_default"
  )
  (via_rule
    90ohm "Via[0-5]_450:300_um-90ohm"
  )
  (via_rule
    100ohm "Via[0-5]_450:300_um-100ohm"
  )
  (class default
    (clearance_class default)
    (via_rule default)
    (rule
      (width 150.0)
    )
    (circuit 
      (use_layer F.Cu In1.Cu In2.Cu In3.Cu In4.Cu B.Cu)
    )
  )
  (class "kicad_default"
    GND 5V 3.3V "Net-(IC1-OUT_B_1)" "Net-(IC1-OUT_A_1)" "Net-(IC2-OUT_B_1)" "Net-(IC2-OUT_A_1)" "Net-(IC3-OUT_B_1)"
    "Net-(IC3-OUT_A_1)" "Net-(IC4-OUT_B_1)" "Net-(IC4-OUT_A_1)" CS6 CS5 "TX7 -> RX" "unconnected-(J1-Pin_1-Pad1)" "RX7 -> TX"
    STATE 12V "Net-(J5-Pin_2)" SCK1 Kicker MISO MOSI CS1
    CS3 CS2 LightGate CS4 48V "unconnected-(MOD1-PadOUT2)" "unconnected-(MOD1-PadA1)" CommModuleRun
    "unconnected-(MOD1-PadTX)" "Net-(IC1-IN_A)" DIR1A "Net-(SW1A-B)" DIR1B "Net-(IC1-IN_B)" "Net-(IC1-PWM)" PWM1
    "Net-(IC2-IN_A)" DIR2A DIR2B "Net-(IC2-IN_B)" PWM2 "Net-(IC2-PWM)" DIR3A "Net-(IC3-IN_A)"
    "Net-(IC3-IN_B)" DIR3B PWM3 "Net-(IC3-PWM)" "Net-(IC4-IN_A)" DIR4A "Net-(IC4-IN_B)" DIR4B
    "Net-(IC4-PWM)" PWM4 "Net-(SW6A-B)" SelectionPin "unconnected-(MOD1-PadA0)" "unconnected-(MOD1-PadRX)" "unconnected-(MOD1-PadVLOG)" "unconnected-(MOD1-Pad+3V3)"
    PWM5 "Net-(U3-In-)" "unconnected-(IC1-CS-Pad13)" "unconnected-(IC1-SEL_0-Pad14)" "unconnected-(IC2-SEL_0-Pad14)" "unconnected-(IC2-CS-Pad13)" "unconnected-(IC3-SEL_0-Pad14)" "unconnected-(IC3-CS-Pad13)"
    "unconnected-(IC4-SEL_0-Pad14)" "unconnected-(IC4-CS-Pad13)" "unconnected-(U4-3V-Pad6)" "unconnected-(U4-PS0-Pad3)" SDA2 "Net-(T401-VCC)" "unconnected-(U12-3V3-Pad15)" "unconnected-(U12-3V3-Pad46)"
    SCL2 "unconnected-(U4-PS1-Pad4)" "unconnected-(U4-ADDR-Pad2)" "unconnected-(U4-INT-Pad1)" "unconnected-(U4-RST-Pad10)" "unconnected-(U12-39_MISO1_OUT1A-Pad31)" "HDMI_+5V" "VBUS_USB2.0"
    "unconnected-(J501-UTILITY{slash}HEAC+-Pad14)" /CM5/PWM /CM5/TACHO /SDA "/CM5/CAM_GPIO1" "/CM5/CAM_GPIO0" /SCL "/CM5/EEPROM_nWP"
    "Net-(R401-Pad2)" "/CM5/ETH_nLED_ACTIVITY" "/CM5/nLED_SPEED_100_1000" "Net-(R402-Pad2)" "Net-(R605-Pad2)" "Net-(D605-K)" "Net-(D606-K)" "/CM5/nLED_ACTIVITY"
    "Net-(U701-ILIM)" /USB/CC2 /USB/CC1 "RX3->TX" "unconnected-(U12-40_A16-Pad32)" "UART3_CTS -> RTS" "UART3_RTS -> CTS" "unconnected-(U12-38_CS1_IN1-Pad30)"
    "TX3->RX" "unconnected-(U405-FAULT-Pad3)" "/CM5/PI_nLED_PWR" "unconnected-(U602-Pad1)" "unconnected-(U701-nFault-Pad4)" "/CM5/VBUS_EN" "/CM5/SCLK_GPIO21" /CM5/GPIO2
    "/CM5/MISO_GPIO19" "/CM5/SD_CMD" +1V8 "/CM5/BL_GPIO18" /CC2 /CM5/GPIO3 /CM5/GPIO12 "/CM5/WL_nDis"
    "/CM5/PWR_BUT" "/CM5/DC_GPI25" /CM5/GPIO11 /CM5/GPIO8 "/CM5/SD_DAT1" /CM5/GPIO26 /CM5/GPIO16 /CM5/GPIO10
    /CM5/GPIO22 "/CM5/GLOBAL_EN" "/CM5/SD_DAT3" "/CM5/SD_PWR_ON" /CM5/GPIO13 "/CM5/SD_DAT0" /CM5/GPIO23 "/CM5/MOSI_GPIO20"
    /CC1 /CM5/GPIO17 "/CM5/ID_SD" /CM5/VBAT "/CM5/SD_DAT2" "/CM5/SYNC_OUT" /CM5/GPIO15 "/CM5/CS_GPIO24"
    /CM5/GPIO14 "/CM5/SD_CLK" "/CM5/BT_nDis" "/CM5/ID_SC" /CM5/GPIO9 /CM5/nRPIBOOT "/CM5/RST_GPIO27" "/CM5/HDMI1_D1_P"
    "/CM5/HDMI1_D0_N" "/CM5/HDMI_PI.SDA" "/CM5/HDMI1_CEC" "/CM5/USB3-0-TX_N" "/CM5/HDMI1_CK_P" "/CM5/HDMI_PI.HOTPLUG" "/CM5/DPHY1_P.D0_P" "/CM5/USB3-1-RX_P"
    "/CM5/HDMI1_D2_N" "/CM5/USB3-0-RX_P" "/CM5/USB3-0-RX_N" "/CM5/USB3-1-RX_N" "/CM5/DPHY1_P.D1_P" "/CM5/HDMI_PI.SCL" "/CM5/DPHY1_P.D3_N" "/CM5/DPHY1_P.D0_N"
    "/CM5/HDMI1_D2_P" "/CM5/HDMI1_D1_N" "/CM5/USB3-0-TX_P" "/CM5/USB3-1-D_N" "/CM5/HDMI1_HOTPLUG" "/CM5/DPHY1_P.C_P" "/CM5/HDMI1_D0_P" "/CM5/DPHY1_P.D3_P"
    "/CM5/DPHY1_P.C_N" "/CM5/DPHY1_P.D1_N" "/CM5/HDMI1_SCL" "/CM5/HDMI1_SDA" "/CM5/USB3-1-TX_N" "/CM5/USB3-1-TX_P" "/CM5/USB3-1-D_P" "/CM5/USBOTG_ID"
    "/CM5/HDMI1_CK_N" "/CM5/HDMI_PI.CEC" "/CM5/DPHY1_P.D2_N" "/CM5/DPHY1_P.D2_P" "unconnected-(Module1A-SD_DAT4-Pad68)" "unconnected-(Module1A-SD_DAT5-Pad64)" "unconnected-(Module1A-SD_VDD_Override-Pad73)" "unconnected-(Module1A-SD_DAT7-Pad70)"
    "unconnected-(Module1A-SD_DAT6-Pad72)" "Net-(J101-VBUS-PadA4)" "unconnected-(J101-SBU1-PadA8)" "unconnected-(J101-SBU2-PadB8)" "unconnected-(USB701-SUB2-PadB8)" "unconnected-(USB701-SUB1-PadA8)" DIR5A "Net-(IC5-OUT_A_1)"
    "Net-(IC5-OUT_B_1)" "Net-(IC5-PWM)" "Net-(IC5-IN_B)" "unconnected-(IC5-CS-Pad13)" "unconnected-(IC5-SEL_0-Pad14)" "Net-(IC5-IN_A)" "unconnected-(U12-33_MCLK2-Pad25)" "unconnected-(U12-34_RX8-Pad26)"
    DIR5B "unconnected-(U12-1_TX1_CTX2_MISO1-Pad3)" "unconnected-(U12-0_RX1_CRX2_CS1-Pad2)"
    (clearance_class "kicad_default")
    (via_rule "kicad_default")
    (rule
      (width 150.0)
    )
    (circuit 
      (use_layer F.Cu In1.Cu In2.Cu In3.Cu In4.Cu B.Cu)
    )
  )
  (class 90ohm
    "/CM5/PCIE_PI.CLK_N" "/CM5/PCIE_PI.RX_P" "/CM5/PCIE_PI.CLK_P" "/CM5/PCIE_PI.PWR_EN" "/CM5/PCIE_PI.nRST" "/CM5/USB2P.D_P" "/CM5/PCIE_PI.TX_P" "/CM5/USB2P.D_N"
    "/CM5/PCIE_PI.nCLKREQ" "/CM5/PCIE_PI.RX_N" "/CM5/PCIE_PI.TX_N" "/CM5/PCIE_PI.nWAKE" "/USB_C.D_N" "/USB_C.D_P"
    (clearance_class 90ohm)
    (via_rule 90ohm)
    (rule
      (width 155.0)
    )
    (circuit 
      (use_layer F.Cu In1.Cu In2.Cu In3.Cu In4.Cu B.Cu)
    )
  )
  (class 100ohm
    "/CM5/ETH_PI.TRD2_N" "/CM5/ETH_PI.TRD2_P" "/CM5/ETH_PI.TRD0_P" "/CM5/ETH_PI.TRD0_N" "/CM5/ETH_PI.TRD1_P" "/CM5/ETH_PI.TRD1_N" "/CM5/ETH_PI.TRD3_N" "/CM5/ETH_PI.TRD3_P"
    "/CM5/HDMI_PI.D0_N" "/CM5/DPHY0_P.D0_N" "/CM5/DPHY0_P.D2_N" "/CM5/DPHY0_P.D3_N" "/CM5/DPHY0_P.C_P" "/CM5/HDMI_PI.CK_N" "/CM5/DPHY0_P.D1_N" "/CM5/DPHY0_P.D0_P"
    "/CM5/DPHY0_P.D2_P" "/CM5/HDMI_PI.D1_P" "/CM5/HDMI_PI.D1_N" "/CM5/HDMI_PI.D2_P" "/CM5/DPHY0_P.D3_P" "/CM5/HDMI_PI.D2_N" "/CM5/HDMI_PI.CK_P" "/CM5/HDMI_PI.D0_P"
    "/CM5/DPHY0_P.D1_P" "/CM5/DPHY0_P.C_N"
    (clearance_class 100ohm)
    (via_rule 100ohm)
    (rule
      (width 122.0)
    )
    (circuit 
      (use_layer F.Cu In1.Cu In2.Cu In3.Cu In4.Cu B.Cu)
    )
  )
)